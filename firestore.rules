rules_version = '2';

// Detail Go — Firestore security rules (Phase 1).
//
// Principles:
//   - Deny by default; grant the minimum each role needs.
//   - Clients touch only their own data and never the money/status fields.
//   - Workers can read searching orders and only advance their own order's status.
//   - Admin has full access. Money + dispatch are finalized by Cloud Functions
//     (Phase 2); these rules already lock the sensitive fields off clients.
//
// NOTE: Phase 2 will tighten worker writes further (field-level checks on the
// exact status transition). This is the Phase-1 baseline.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return isSignedIn() ? userDoc().role : '';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    // --- users -------------------------------------------------------------
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // A client may create ONLY their own document, and only with role 'client'
      // and active == true (cannot self-promote to worker/admin).
      // The admin may create any user doc (used to onboard detailers/workers).
      allow create: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == 'client'
            && request.resource.data.active == true);

      // A user may toggle their own `available` flag, set their own profile
      // photo and save their push token; everything else about a user doc is
      // admin-only.
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['available', 'photoUrl', 'pushToken']));

      allow delete: if isAdmin();

      // Private subcollections: only the owner (or admin) reads/writes.
      match /{sub=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    // --- services ----------------------------------------------------------
    // Public catalog: anyone (even logged out) can browse services before
    // signing up. Only the admin can create/edit/remove packages.
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- extras ------------------------------------------------------------
    // Extra services (quoted per vehicle). Public catalog read, admin write.
    match /extras/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- bookings ----------------------------------------------------------
    match /bookings/{id} {
      // Which top-level keys an update touches.
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }
      // The money split and order contents can NEVER be rewritten by a client or
      // worker after creation — only admin (and Cloud Functions later) may.
      function moneyFrozen() {
        return request.resource.data.total == resource.data.total
          && request.resource.data.workerPayout == resource.data.workerPayout
          && request.resource.data.businessFee == resource.data.businessFee
          && request.resource.data.clientId == resource.data.clientId
          && request.resource.data.items == resource.data.items;
      }
      // The assigned worker cannot be changed by a normal update (only by the
      // dedicated "claim" branch below, which starts from a null workerId).
      function workerFrozen() {
        return request.resource.data.workerId == resource.data.workerId;
      }

      allow read: if isSignedIn() && (
        isAdmin()
        || resource.data.clientId == request.auth.uid
        || resource.data.workerId == request.auth.uid
        || (role() == 'worker' && resource.data.status == 'searching_worker')
      );

      // Client creates their own order. Money/status are constrained so a
      // client cannot forge a confirmed/paid order or a bogus payout: the split
      // must add up (total = worker payout + business fee), be non-negative, and
      // start unassigned in an entry status.
      allow create: if isSignedIn()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.workerId == null
        && request.resource.data.total == request.resource.data.workerPayout + request.resource.data.businessFee
        && request.resource.data.workerPayout >= 0
        && request.resource.data.businessFee >= 0
        && request.resource.data.status in ['pending_payment', 'searching_worker'];

      // Admin drives verification/cancellation (full access). Client and worker
      // are locked to the exact fields their screens touch, with money and the
      // worker assignment frozen — so neither can forge a payout or skip steps.
      allow update: if isAdmin()
        // Client edits only their own order: re-upload a receipt, submit a
        // review, or cancel. Status may only move to re-submit or cancellation.
        || (isSignedIn()
            && resource.data.clientId == request.auth.uid
            && changedKeys().hasOnly(['payment', 'status', 'review', 'cancelledBy', 'cancelReason', 'updatedAt'])
            && moneyFrozen()
            && workerFrozen()
            && request.resource.data.status in ['pending_payment', 'cancelled', resource.data.status])
        // Worker who already owns the order advances its status only.
        || (isSignedIn()
            && resource.data.workerId == request.auth.uid
            && changedKeys().hasOnly(['status', 'updatedAt'])
            && moneyFrozen()
            && workerFrozen()
            && request.resource.data.status in ['on_the_way', 'arrived', 'in_progress', 'completed', 'payment_issue'])
        // A worker claims a searching order ("first to accept wins"): they may
        // only set themselves as the worker and move searching → assigned.
        || (role() == 'worker'
            && resource.data.status == 'searching_worker'
            && changedKeys().hasOnly(['status', 'workerId', 'workerName', 'updatedAt'])
            && request.resource.data.workerId == request.auth.uid
            && request.resource.data.status == 'assigned'
            && moneyFrozen());

      allow delete: if isAdmin();
    }

    // --- counters (sequential detailer IDs) --------------------------------
    // Admin-only: used to hand out DET-001, DET-002… when creating detailers.
    match /counters/{id} {
      allow read, write: if isAdmin();
    }

    // --- applications (public "work here" form) ----------------------------
    // Anyone (even unauthenticated) may apply, but the payload is bounded so the
    // open endpoint cannot be used to dump garbage or self-approve: it must be a
    // fresh 'pending' application with sane, size-capped fields.
    match /applications/{id} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 120
        && request.resource.data.phone is string
        && request.resource.data.phone.size() < 40
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200
        && request.resource.data.comment is string
        && request.resource.data.comment.size() < 2000;
      allow read, update, delete: if isAdmin();
    }
  }
}
