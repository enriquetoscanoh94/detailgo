{
  "expo": {
    "name": "Detail Go",
    "slug": "detailgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "detailgo",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#06101F",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.detailgo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Detail Go usa la cámara para que puedas tomar la foto de tu comprobante de pago.",
        "NSPhotoLibraryUsageDescription": "Detail Go accede a tus fotos para subir el comprobante de pago de tu servicio."
      }
    },
    "android": {
      "package": "com.detailgo.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0A0F1E",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "Detail Go accede a tus fotos para subir el comprobante de pago de tu servicio.",
          "cameraPermission": "Detail Go usa la cámara para que puedas tomar la foto de tu comprobante de pago."
        }
      ],
      "expo-localization",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#06B6D4",
          "sounds": ["./assets/ring.wav"]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/van.png",
          "backgroundColor": "#06101F",
          "resizeMode": "contain",
          "imageWidth": 260
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8982ba52-f93c-4c32-98e2-6adb5ac99133"
      }
    },
    "owner": "detailgoapps-team"
  }
}
